APP_NAME=KaziBora
APP_ENV=local
APP_KEY=base64:GENERATE_A_KEY_HERE
APP_DEBUG=true
APP_URL=http://localhost:9000

# Database (shared MariaDB instance)
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=kazibora
DB_USERNAME=root
DB_PASSWORD=root

# Queue
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379

# Microservices
NLP_SERVICE_URL=http://nlp-service:8000
MATCHER_SERVICE_URL=http://matcher-api:8001

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_TTL=1440

# M-Pesa Daraja API
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
MPESA_ENV=sandbox
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback
